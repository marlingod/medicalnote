DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-to-a-random-string
DB_NAME=medicalnote
DB_USER=medicalnote
DB_PASSWORD=medicalnote
DB_HOST=localhost
DB_PORT=5432
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
REDIS_URL=redis://localhost:6379/2
FIELD_ENCRYPTION_KEY=change-me-to-a-32-byte-base64-key=
AWS_REGION=us-east-1
AWS_S3_BUCKET=medicalnote-hipaa-dev
AWS_KMS_KEY_ID=
# LLM Provider: "claude" | "gemini" | "claude+gemini"
#   claude       = Claude for all tasks (default)
#   gemini       = Gemini for all tasks (~60% cheaper)
#   claude+gemini = Claude for SOAP/quality, Gemini for summaries (best value)
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
