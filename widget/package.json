{
  "name": "@medicalnote/widget-sdk",
  "version": "1.0.0",
  "description": "MedicalNote White-Label Patient Summary Widget",
  "main": "dist/widget.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c --watch",
    "test": "vitest run",
