  "devDependencies": {
    "typescript": "^5.4.0",
    "rollup": "^4.12.0",
    "@rollup/plugin-typescript": "^11.1.0",
    "@rollup/plugin-terser": "^0.4.0",
    "rollup-plugin-postcss": "^4.0.0",
    "tslib": "^2.6.0",
    "vitest": "^1.3.0",
    "jsdom": "^24.0.0",
    "@vitest/coverage-v8": "^1.3.0"
  }
}
